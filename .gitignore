# Build / cache（顶层 build/ 会忽略仓库内任意名为 build/ 的目录，含 desktop/build/）
build/
.task/
*.exe
.DS_Store

# Go
*.test

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# --- desktop/（Wails + Vite）---
# 安装依赖
desktop/frontend/node_modules/

# Vite 构建产物（wails build / npm run build；带 hash 的 assets 等）
desktop/frontend/dist/

# Wails 生成的 JS/TS 绑定与 runtime（wails dev / wails build 会重写）
desktop/frontend/wailsjs/

# Wails 缓存的前端 package.json 指纹
desktop/frontend/package.json.md5

# Wails 产物目录（可执行包、.app 等；与仓库根 build/ 不同名，需单独写）
desktop/bin/

# 本地环境变量（若前端后续使用 Vite env）
desktop/frontend/.env.local
desktop/frontend/.env.*.local
